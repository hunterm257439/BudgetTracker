<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - BudgetTracker</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BudgetTracker.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-dark bg-dark shadow-sm mb-0">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Budget" asp-action="Index">
                    BudgetTracker
                </a>
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1 gap-1">
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded" asp-controller="Budget" asp-action="Index">Budget</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded" asp-controller="Transactions" asp-action="Index">Transactions</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded" asp-controller="BankAccounts" asp-action="Index">Bank Accounts</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link px-3 rounded" asp-controller="Categories" asp-action="Index">Categories</a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        @* Thin gradient accent line below the navbar *@
        <div style="height: 3px; background: linear-gradient(90deg, #0d6efd 0%, #198754 100%);"></div>
    </header>

    <div class="container pt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - BudgetTracker - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    @* Highlight the active nav link based on the current URL path *@
    <script>
        var path = window.location.pathname.toLowerCase();
        document.querySelectorAll('.navbar-nav .nav-link').forEach(function(link) {
            var segment = (link.getAttribute('href') || '').split('/')[1] || '';
            if (segment && path.includes(segment.toLowerCase())) {
                link.classList.add('active');
                link.style.backgroundColor = 'rgba(255,255,255,0.12)';
            }
        });
    </script>
</body>
</html>
