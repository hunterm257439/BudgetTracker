@model IEnumerable<BudgetTracker.Models.Category>
@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Categories</h2>
    <a asp-action="Create" class="btn btn-primary">+ Add Category</a>
</div>

<p class="text-muted small mb-3">Drag the <span class="text-secondary">&#9776;</span> handle to reorder categories and subcategories.</p>

@if (!Model.Any())
{
    <p class="text-muted">No categories yet. <a asp-action="Create">Add one</a> to get started.</p>
}

@* id="category-list" is how JavaScript will find this container to make it sortable *@
<div id="category-list">
    @foreach (var category in Model)
    {
        @* data-category-id stores the ID so JavaScript knows which category moved *@
        <div class="card mb-3 category-card" data-category-id="@category.Id">
            <div class="card-header d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    @* The drag handle — only this element triggers dragging, not the whole card *@
                    <span class="drag-handle text-muted" style="cursor: grab; font-size: 1.1rem;" title="Drag to reorder">&#9776;</span>
                    <strong>@category.Name</strong>
                </div>
                <div class="d-flex gap-2">
                    <a asp-controller="Subcategories" asp-action="Create" asp-route-categoryId="@category.Id"
                       class="btn btn-sm btn-outline-primary">+ Subcategory</a>
                    <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                    <a asp-action="Delete" asp-route-id="@category.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                </div>
            </div>

            @if (category.Subcategories.Any())
            {
                @* subcategory-list class lets JavaScript find these lists to make them sortable *@
                <ul class="list-group list-group-flush subcategory-list">
                    @foreach (var sub in category.Subcategories.OrderBy(s => s.SortOrder).ThenBy(s => s.Name))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center subcategory-item"
                            data-subcategory-id="@sub.Id">
                            <div class="d-flex align-items-center gap-2">
                                <span class="drag-handle text-muted" style="cursor: grab;" title="Drag to reorder">&#9776;</span>
                                <span>@sub.Name</span>
                            </div>
                            <div class="d-flex gap-2">
                                <a asp-controller="Subcategories" asp-action="Edit" asp-route-id="@sub.Id"
                                   class="btn btn-sm btn-outline-secondary">Edit</a>
                                <a asp-controller="Subcategories" asp-action="Delete" asp-route-id="@sub.Id"
                                   class="btn btn-sm btn-outline-danger">Delete</a>
                            </div>
                        </li>
                    }
                </ul>
            }
            else
            {
                <div class="card-body text-muted small">No subcategories yet.</div>
            }
        </div>
    }
</div>

@section Scripts {
    @* Load SortableJS from a CDN. The browser downloads this file once and caches it. *@
    <script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.2/Sortable.min.js"></script>
    <script>
        // Make the category cards draggable
        var categoryList = document.getElementById('category-list');
        Sortable.create(categoryList, {
            handle: '.drag-handle',   // only the ☰ icon triggers dragging
            draggable: '.category-card',
            animation: 150,           // smooth 150ms slide animation while dragging

            // onEnd fires when the user drops an item
            onEnd: function () {
                // Collect the new order: read data-category-id from each card in DOM order
                var ids = Array.from(categoryList.querySelectorAll('.category-card'))
                    .map(function(el) { return parseInt(el.dataset.categoryId); });

                // Send the new order to the server
                fetch('/Categories/ReorderCategories', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(ids)
                });
            }
        });

        // Make subcategories draggable within each category card
        document.querySelectorAll('.subcategory-list').forEach(function(list) {
            Sortable.create(list, {
                handle: '.drag-handle',
                draggable: '.subcategory-item',
                animation: 150,
                onEnd: function () {
                    var ids = Array.from(list.querySelectorAll('.subcategory-item'))
                        .map(function(el) { return parseInt(el.dataset.subcategoryId); });

                    fetch('/Categories/ReorderSubcategories', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify(ids)
                    });
                }
            });
        });
    </script>
}
