@model IEnumerable<BudgetTracker.Models.Transaction>
@{
    ViewData["Title"] = "Transactions";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Transactions</h2>
    <div class="d-flex gap-2">
        <a asp-action="ImportCsv" class="btn btn-outline-secondary">Import CSV</a>
        <a asp-action="Create" class="btn btn-primary">+ Add Transaction</a>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <p class="text-muted">No transactions yet. <a asp-action="Create">Add one</a> to get started.</p>
}
else
{
    <table class="table table-hover">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Payee</th>
                <th>Account</th>
                <th>Category</th>
                <th class="text-end">Outflow</th>
                <th class="text-end">Inflow</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model)
            {
                <tr>
                    <td>@t.Date.ToString("MM/dd/yyyy")</td>
                    <td>@t.Payee</td>
                    <td>@t.BankAccount?.Name</td>
                    <td>
                        @t.Subcategory?.Category?.Name
                        @if (t.Subcategory != null)
                        {
                            <text> &rsaquo; </text>@t.Subcategory.Name
                        }
                    </td>
                    <td class="text-end text-danger">
                        @(t.Outflow.HasValue ? t.Outflow.Value.ToString("C") : "")
                    </td>
                    <td class="text-end text-success">
                        @(t.Inflow.HasValue ? t.Inflow.Value.ToString("C") : "")
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                        <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
