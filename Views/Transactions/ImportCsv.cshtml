@{
    ViewData["Title"] = "Import Transactions from CSV";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Import Transactions</h2>
    <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
</div>

@* Show any row-level errors from a previous failed import attempt *@
@if (ViewBag.Errors != null)
{
    <div class="alert alert-danger">
        <strong>Import failed — fix these errors in your CSV and try again:</strong>
        <ul class="mb-0 mt-2">
            @foreach (var error in (List<string>)ViewBag.Errors)
            {
                <li>@error</li>
            }
        </ul>
    </div>
}

@* enctype="multipart/form-data" is REQUIRED for file uploads.
   Without it, the browser sends just the filename, not the file contents. *@
<form asp-action="ImportCsv" method="post" enctype="multipart/form-data">
    @Html.AntiForgeryToken()

    <div class="card mb-4">
        <div class="card-header"><strong>Upload CSV File</strong></div>
        <div class="card-body">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label class="form-label">Choose file</label>
                <input type="file" name="file" accept=".csv" class="form-control" required />
                <div class="form-text">File must be a .csv with the format described below.</div>
            </div>

            <button type="submit" class="btn btn-primary">Import</button>
        </div>
    </div>
</form>

<div class="card">
    <div class="card-header"><strong>Expected CSV Format</strong></div>
    <div class="card-body">
        <p>The first row must be a header row (it will be skipped). Columns in order:</p>
        <table class="table table-sm table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Column</th>
                    <th>Required?</th>
                    <th>Example</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                <tr><td>Date</td><td>Yes</td><td>2026-01-15</td><td>YYYY-MM-DD or MM/DD/YYYY</td></tr>
                <tr><td>Payee</td><td>Yes</td><td>Grocery Store</td><td>Free text</td></tr>
                <tr><td>Account</td><td>Yes</td><td>Checking</td><td>Must match an existing account name exactly</td></tr>
                <tr><td>Subcategory</td><td>Yes</td><td>Groceries <em>or</em> Food &gt; Groceries</td><td>Name alone or "Category &gt; Subcategory"</td></tr>
                <tr><td>Outflow</td><td>One of these</td><td>45.67</td><td>Leave blank if not applicable</td></tr>
                <tr><td>Inflow</td><td>is required</td><td>2000.00</td><td>Leave blank if not applicable</td></tr>
            </tbody>
        </table>

        <p><strong>Example file contents:</strong></p>
        <pre class="bg-light p-3 rounded">Date,Payee,Account,Subcategory,Outflow,Inflow
2026-01-15,Grocery Store,Checking,Groceries,45.67,
2026-01-20,Paycheck,Checking,Salary,,2000.00
2026-01-22,Electric Bill,Checking,Utilities,120.00,</pre>

        @if (ViewBag.AccountNames != null)
        {
            <p class="mt-3"><strong>Your existing accounts:</strong>
                @string.Join(", ", (List<string>)ViewBag.AccountNames)
            </p>
        }

        @if (ViewBag.SubcategoryNames != null)
        {
            <p><strong>Your existing subcategories:</strong></p>
            <ul class="small">
                @foreach (var name in (List<string>)ViewBag.SubcategoryNames)
                {
                    <li>@name</li>
                }
            </ul>
        }
    </div>
</div>
