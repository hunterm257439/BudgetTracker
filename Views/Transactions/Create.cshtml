@model BudgetTracker.Models.Transaction
@{
    ViewData["Title"] = "Add Transaction";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Add Transaction</h2>
        <form asp-action="Create" method="post">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Date" class="form-label"></label>
                <input asp-for="Date" class="form-control" type="date" />
                <span asp-validation-for="Date" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Payee" class="form-label"></label>
                <input asp-for="Payee" class="form-control" placeholder="e.g. Amazon, Landlord, Employer" />
                <span asp-validation-for="Payee" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BankAccountId" class="form-label">Account</label>
                <select asp-for="BankAccountId" class="form-select" asp-items="ViewBag.BankAccounts">
                    <option value="">-- Select an Account --</option>
                </select>
                <span asp-validation-for="BankAccountId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SubcategoryId" class="form-label">Subcategory</label>
                <select asp-for="SubcategoryId" class="form-select" asp-items="ViewBag.Subcategories">
                    <option value="">-- Select a Subcategory --</option>
                </select>
                <span asp-validation-for="SubcategoryId" class="text-danger"></span>
            </div>

            <div class="row mb-3">
                <div class="col">
                    <label asp-for="Outflow" class="form-label">Outflow (Money Going Out)</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Outflow" class="form-control" type="number" step="0.01" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Outflow" class="text-danger"></span>
                </div>
                <div class="col">
                    <label asp-for="Inflow" class="form-label">Inflow (Money Coming In)</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input asp-for="Inflow" class="form-control" type="number" step="0.01" placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Inflow" class="text-danger"></span>
                </div>
            </div>
            <div class="form-text mb-3">Fill in either Outflow or Inflow (or both if applicable).</div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
