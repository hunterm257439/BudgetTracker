@model BudgetTracker.Models.ViewModels.BudgetViewModel
@{
    ViewData["Title"] = "Budget — " + Model.MonthName;

    string FormatAmount(decimal amount) => amount.ToString("C");

    string AmountClass(decimal amount) =>
        amount < 0 ? "text-danger" : (amount > 0 ? "" : "text-muted");

    var prevMonth = Model.Month == 1 ? 12 : Model.Month - 1;
    var prevYear  = Model.Month == 1 ? Model.Year - 1 : Model.Year;
    var nextMonth = Model.Month == 12 ? 1 : Model.Month + 1;
    var nextYear  = Model.Month == 12 ? Model.Year + 1 : Model.Year;
}

@* ── Page header ──────────────────────────────────────────────────────────── *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0 fw-bold">Budget</h2>
        <div class="text-muted small">Your spending plan for the month</div>
    </div>
    <div class="d-flex align-items-center gap-2">
        <a asp-action="Index" asp-route-month="@prevMonth" asp-route-year="@prevYear"
           class="btn btn-outline-secondary btn-sm rounded-pill">&larr;</a>
        <span class="fw-semibold fs-5 px-2">@Model.MonthName</span>
        <a asp-action="Index" asp-route-month="@nextMonth" asp-route-year="@nextYear"
           class="btn btn-outline-secondary btn-sm rounded-pill">&rarr;</a>
    </div>
</div>

@* ── Ready to Budget card ─────────────────────────────────────────────────── *@
<div class="card shadow-sm border-0 mb-3 atb-card @(Model.AvailableToBudget >= 0 ? "atb-positive" : "atb-negative")">
    <div class="card-body py-3 d-flex justify-content-between align-items-center flex-wrap gap-3">
        <div>
            <div class="text-uppercase fw-semibold small mb-1 text-muted" style="letter-spacing:.05em">
                Ready to Budget
            </div>
            <div class="fs-4 fw-bold @AmountClass(Model.AvailableToBudget)">
                @FormatAmount(Model.AvailableToBudget)
            </div>
            <div class="text-muted small">Account balances minus all assigned amounts</div>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Categories" asp-action="Create"
               class="btn btn-outline-secondary btn-sm rounded-pill">+ Category</a>
            <a asp-controller="Transactions" asp-action="Create"
               class="btn btn-primary btn-sm rounded-pill">+ Transaction</a>
        </div>
    </div>
</div>

@* ── Feature 3: Income vs. Targets panel ─────────────────────────────────── *@
<div class="card mb-3">
    <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-center gap-3">

            @* Editable income field *@
            <div class="d-flex align-items-center gap-2">
                <label class="form-label mb-0 text-muted small">Expected Income/mo:</label>
                <div class="input-group input-group-sm" style="width: 150px;">
                    <span class="input-group-text">$</span>
                    <input type="number" id="incomeInput" class="form-control"
                           step="0.01" min="0"
                           value="@(Model.ExpectedMonthlyIncome?.ToString("F2") ?? "")"
                           placeholder="0.00" />
                </div>
                <button class="btn btn-outline-primary btn-sm" id="saveIncomeBtn">Save</button>
            </div>

            @* Total monthly targets (read-only, auto-calculated) *@
            <div class="text-muted small">
                Total Targets/mo:
                <strong class="text-dark">@FormatAmount(Model.TotalMonthlyTargets)</strong>
            </div>

            @* Surplus or Deficit *@
            @if (Model.IncomeSurplusOrDeficit.HasValue)
            {
                var diff     = Model.IncomeSurplusOrDeficit.Value;
                var diffCls  = diff >= 0 ? "text-success fw-semibold" : "text-danger fw-semibold";
                var diffLbl  = diff >= 0 ? "Surplus" : "Deficit";
                <div class="small">
                    @diffLbl: <span class="@diffCls">@FormatAmount(Math.Abs(diff))</span>
                </div>
            }
            else
            {
                <div class="text-muted small fst-italic">Set income above to see surplus/deficit.</div>
            }
        </div>
    </div>
</div>

@* ── Empty state ──────────────────────────────────────────────────────────── *@
@if (!Model.Categories.Any())
{
    <div class="text-center py-5">
        <div style="font-size: 3rem;">&#128176;</div>
        <h5 class="text-muted fw-normal mt-2">No categories yet</h5>
        <p class="text-muted small">Create a category to start building your budget.</p>
        <a asp-controller="Categories" asp-action="Create" class="btn btn-primary rounded-pill px-4">
            + Add First Category
        </a>
    </div>
}
else
{
    @* ── Feature 2: New-month carry-forward hint ────────────────────────────── *@
    @if (Model.IsUnassignedNewMonth)
    {
        <div class="alert alert-light border small py-2 mb-2">
            <strong>New month?</strong> Your Available balances already include unspent money from
            prior months — you only need to assign new money if you want to add more to a category.
        </div>
    }

    <p class="text-muted small mb-2">
        Click any <strong>Assigned</strong> value to edit it inline.
        Press <kbd>Enter</kbd> to save or <kbd>Esc</kbd> to cancel.
    </p>

    @* ── Budget table ─────────────────────────────────────────────────────── *@
    <div class="card shadow-sm rounded-3 overflow-hidden">
        <div class="table-responsive">
            <table class="table table-bordered table-sm table-hover mb-0">
                <thead class="table-dark" style="position: sticky; top: 0; z-index: 1;">
                    <tr>
                        <th style="width: 50%">Category / Subcategory</th>
                        <th class="text-end">Assigned</th>
                        <th class="text-end">Activity</th>
                        <th class="text-end">Available</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        @* Category header row *@
                        <tr class="table-secondary fw-semibold">
                            <td>
                                <div class="d-flex justify-content-between align-items-center">
                                    <span style="font-size: 0.8rem; letter-spacing: 0.04em; text-transform: uppercase;">
                                        @category.CategoryName
                                    </span>
                                    <a asp-controller="Subcategories" asp-action="Create"
                                       asp-route-categoryId="@category.CategoryId"
                                       class="btn btn-link btn-sm py-0 px-1 text-secondary fw-normal"
                                       style="font-size: 0.75rem;"
                                       title="Add subcategory to @category.CategoryName">+ Add</a>
                                </div>
                            </td>
                            <td class="text-end @AmountClass(category.TotalAssigned)">@FormatAmount(category.TotalAssigned)</td>
                            <td class="text-end @AmountClass(category.TotalActivity)">@FormatAmount(category.TotalActivity)</td>
                            <td class="text-end @AmountClass(category.TotalAvailable)">@FormatAmount(category.TotalAvailable)</td>
                        </tr>

                        @if (!category.Subcategories.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-muted small ps-4">
                                    No subcategories.
                                    <a asp-controller="Subcategories" asp-action="Create"
                                       asp-route-categoryId="@category.CategoryId">Add one</a>
                                </td>
                            </tr>
                        }

                        @foreach (var sub in category.Subcategories)
                        {
                            <tr>
                                @* Subcategory name + Set Target button *@
                                <td class="ps-4">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <span>@sub.SubcategoryName</span>
                                        <button class="btn btn-outline-secondary btn-sm py-0 fw-normal set-target-btn"
                                                style="font-size: 0.75rem;"
                                                data-subcategory-id="@sub.SubcategoryId"
                                                data-subcategory-name="@sub.SubcategoryName"
                                                data-target-amount="@sub.TargetAmount"
                                                data-target-period="@((int?)sub.Period)"
                                                data-target-day="@sub.TargetDay">
                                            @(sub.HasTarget ? "Edit Target" : "Set Target")
                                        </button>
                                    </div>
                                </td>

                                @* Assigned cell — click to edit inline *@
                                <td class="text-end assigned-cell"
                                    data-subcategory-id="@sub.SubcategoryId"
                                    data-month="@Model.Month"
                                    data-year="@Model.Year"
                                    title="Click to edit"
                                    style="cursor: pointer;">
                                    <span class="assigned-display @AmountClass(sub.Assigned)">@FormatAmount(sub.Assigned)</span>
                                    <input type="number"
                                           class="form-control form-control-sm assigned-input d-none"
                                           step="0.01"
                                           value="@sub.Assigned"
                                           style="width: 110px; margin-left: auto;" />
                                </td>

                                <td class="text-end @AmountClass(sub.Activity)">@FormatAmount(sub.Activity)</td>

                                @* Available cell — colored pill + progress bar when target is set *@
                                @if (sub.HasTarget)
                                {
                                    var pillClass = sub.TargetMet
                                        ? "badge bg-success fs-6 fw-normal"
                                        : "badge bg-warning text-dark fs-6 fw-normal";
                                    var barClass = sub.TargetMet ? "bg-success" : "bg-warning";
                                    <td class="text-end">
                                        <span class="@pillClass"
                                              title="Target: @FormatAmount(sub.MonthlyTargetAmount)/mo">
                                            @FormatAmount(sub.Available)
                                        </span>
                                        @* Feature 2: carry-forward badge *@
                                        @if (sub.HasCarryForward)
                                        {
                                            <br />
                                            <span class="badge bg-secondary fw-normal"
                                                  style="font-size: 0.65rem;"
                                                  title="Balance carried forward from prior months">carried</span>
                                        }
                                        @* Feature 1: progress bar *@
                                        <div class="progress budget-target-bar"
                                             title="@sub.TargetProgressPercent% of target">
                                            <div class="progress-bar @barClass"
                                                 role="progressbar"
                                                 style="width: @sub.TargetProgressPercent%;"
                                                 aria-valuenow="@sub.TargetProgressPercent"
                                                 aria-valuemin="0"
                                                 aria-valuemax="100"></div>
                                        </div>
                                    </td>
                                }
                                else
                                {
                                    <td class="text-end @AmountClass(sub.Available)">
                                        @FormatAmount(sub.Available)
                                        @* Feature 2: carry-forward badge *@
                                        @if (sub.HasCarryForward)
                                        {
                                            <br />
                                            <span class="badge bg-secondary fw-normal"
                                                  style="font-size: 0.65rem;"
                                                  title="Balance carried forward from prior months">carried</span>
                                        }
                                    </td>
                                }
                            </tr>
                        }
                    }
                </tbody>
                <tfoot class="table-dark fw-bold">
                    <tr>
                        <td>Totals</td>
                        <td class="text-end @AmountClass(Model.TotalAssigned)">@FormatAmount(Model.TotalAssigned)</td>
                        <td class="text-end @AmountClass(Model.TotalActivity)">@FormatAmount(Model.TotalActivity)</td>
                        <td class="text-end @AmountClass(Model.TotalAvailable)">@FormatAmount(Model.TotalAvailable)</td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
}

@* ── Target modal ─────────────────────────────────────────────────────────────
   A single Bootstrap modal shared by all subcategory rows.
   JavaScript fills in the right values each time "Set Target" is clicked. *@
<div class="modal fade" id="targetModal" tabindex="-1"
     aria-labelledby="targetModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="targetModalLabel">Set Target</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="targetSubcategoryId" />

                <div class="mb-3">
                    <label class="form-label">Target Amount</label>
                    <div class="input-group">
                        <span class="input-group-text">$</span>
                        <input type="number" id="targetAmountInput" class="form-control"
                               min="0.01" step="0.01" placeholder="0.00" />
                    </div>
                    <div class="form-text">The dollar amount you want to have available.</div>
                </div>

                <div class="mb-3">
                    <label class="form-label">Period</label>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   name="targetPeriod" id="periodMonthly" value="1" />
                            <label class="form-check-label" for="periodMonthly">Monthly</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio"
                                   name="targetPeriod" id="periodYearly" value="2" />
                            <label class="form-check-label" for="periodYearly">Yearly</label>
                        </div>
                    </div>
                </div>

                <div class="mb-3" id="modalTargetDayRow" style="display:none">
                    <label class="form-label" id="modalTargetDayLabel">Day needed</label>
                    <input type="number" id="targetDayInput" class="form-control"
                           min="1" max="366" step="1" />
                    <div class="form-text" id="modalTargetDayHelp"></div>
                </div>

                <div id="targetSummary" class="alert alert-info py-2 small" style="display:none"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-danger me-auto" id="clearTargetBtn">
                    Clear Target
                </button>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="saveTargetBtn">Save Target</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
    // ── Assigned cell inline editing ────────────────────────────────────────

    document.querySelectorAll('.assigned-cell').forEach(function(cell) {

        cell.addEventListener('click', function() {
            var display = cell.querySelector('.assigned-display');
            var input   = cell.querySelector('.assigned-input');
            display.classList.add('d-none');
            input.classList.remove('d-none');
            input.focus();
            input.select();
        });

        var input = cell.querySelector('.assigned-input');

        input.addEventListener('keydown', function(e) {
            if (e.key === 'Enter')  { e.preventDefault(); saveAssignment(cell, input); }
            if (e.key === 'Escape') { cancelEdit(cell, input); }
        });
        input.addEventListener('blur', function() {
            setTimeout(function() { saveAssignment(cell, input); }, 100);
        });
    });

    function cancelEdit(cell, input) {
        input.classList.add('d-none');
        cell.querySelector('.assigned-display').classList.remove('d-none');
    }

    async function saveAssignment(cell, input) {
        if (input.classList.contains('d-none')) return;

        var amount   = parseFloat(input.value) || 0;
        var response = await fetch('/Budget/UpdateAssignment', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                subcategoryId: parseInt(cell.dataset.subcategoryId),
                month:         parseInt(cell.dataset.month),
                year:          parseInt(cell.dataset.year),
                amount:        amount
            })
        });

        if (response.ok) {
            location.reload();
        } else {
            alert('Failed to save. Please try again.');
            cancelEdit(cell, input);
        }
    }

    // ── Target modal ────────────────────────────────────────────────────────

    document.querySelectorAll('.set-target-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.getElementById('targetSubcategoryId').value = btn.dataset.subcategoryId;
            document.getElementById('targetModalLabel').textContent =
                'Set Target: ' + btn.dataset.subcategoryName;

            document.getElementById('targetAmountInput').value = btn.dataset.targetAmount || '';

            document.querySelectorAll('input[name="targetPeriod"]').forEach(r => r.checked = false);
            var period = btn.dataset.targetPeriod;
            if (period) {
                var radio = document.querySelector('input[name="targetPeriod"][value="' + period + '"]');
                if (radio) radio.checked = true;
            }

            document.getElementById('targetDayInput').value = btn.dataset.targetDay || '';
            updateModalDayRow(period);
            updateTargetSummary();

            new bootstrap.Modal(document.getElementById('targetModal')).show();
        });
    });

    document.querySelectorAll('input[name="targetPeriod"]').forEach(function(radio) {
        radio.addEventListener('change', function() {
            updateModalDayRow(this.value);
            updateTargetSummary();
        });
    });
    document.getElementById('targetAmountInput').addEventListener('input', updateTargetSummary);
    document.getElementById('targetDayInput').addEventListener('input', updateTargetSummary);

    function updateModalDayRow(period) {
        var row   = document.getElementById('modalTargetDayRow');
        var label = document.getElementById('modalTargetDayLabel');
        var help  = document.getElementById('modalTargetDayHelp');
        if (period == 1) {
            row.style.display = '';
            label.textContent = 'Day of month needed (1–31)';
            help.textContent  = 'The day of the month by which this amount should be available.';
        } else if (period == 2) {
            row.style.display = '';
            label.textContent = 'Day of year needed (1–366)';
            help.textContent  = 'The day of the year by which this amount should be available (e.g. 180 = June 29).';
        } else {
            row.style.display = 'none';
        }
    }

    function updateTargetSummary() {
        var summary = document.getElementById('targetSummary');
        var amount  = parseFloat(document.getElementById('targetAmountInput').value);
        var radio   = document.querySelector('input[name="targetPeriod"]:checked');
        if (!amount || !radio) { summary.style.display = 'none'; return; }

        var monthly = radio.value == 2 ? (amount / 12) : amount;
        summary.style.display = '';
        summary.textContent = 'You need '
            + monthly.toLocaleString('en-US', { style: 'currency', currency: 'USD' })
            + ' available per month to hit this target. '
            + 'The Available pill will turn green when you reach that amount.';
    }

    document.getElementById('saveTargetBtn').addEventListener('click', async function() {
        var subcategoryId = parseInt(document.getElementById('targetSubcategoryId').value);
        var amountStr     = document.getElementById('targetAmountInput').value;
        var targetAmount  = amountStr ? parseFloat(amountStr) : null;
        var radio         = document.querySelector('input[name="targetPeriod"]:checked');
        var period        = radio ? parseInt(radio.value) : null;
        var dayStr        = document.getElementById('targetDayInput').value;
        var targetDay     = dayStr ? parseInt(dayStr) : null;

        if (targetAmount && !period) {
            alert('Please select Monthly or Yearly.');
            return;
        }

        var response = await fetch('/Budget/SaveTarget', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ subcategoryId, targetAmount, period, targetDay })
        });

        if (response.ok) { location.reload(); }
        else { alert('Failed to save target. Please try again.'); }
    });

    document.getElementById('clearTargetBtn').addEventListener('click', async function() {
        var subcategoryId = parseInt(document.getElementById('targetSubcategoryId').value);
        var response = await fetch('/Budget/SaveTarget', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ subcategoryId, targetAmount: null, period: null, targetDay: null })
        });
        if (response.ok) { location.reload(); }
        else { alert('Failed to clear target. Please try again.'); }
    });

    // ── Income save ─────────────────────────────────────────────────────────

    document.getElementById('saveIncomeBtn').addEventListener('click', async function() {
        var val    = document.getElementById('incomeInput').value;
        var income = val !== '' ? parseFloat(val) : null;
        var res    = await fetch('/Budget/SaveSettings', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ expectedMonthlyIncome: income })
        });
        if (res.ok) { location.reload(); }
        else { alert('Failed to save income. Please try again.'); }
    });
</script>
}
