@model BudgetTracker.Models.BudgetAssignment
@{
    ViewData["Title"] = "Set Budget";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2>Set Assigned Amount</h2>
        <p class="text-muted">
            <strong>@ViewBag.SubcategoryName</strong> &mdash; @ViewBag.MonthName
        </p>

        <form asp-action="SetAssignment" method="post">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="SubcategoryId" />
            <input type="hidden" asp-for="Month" />
            <input type="hidden" asp-for="Year" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Amount" class="form-label">Assigned Amount</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" />
                </div>
                <div class="form-text">This is the amount you're allocating to this subcategory for @ViewBag.MonthName. Can be positive or negative.</div>
                <span asp-validation-for="Amount" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" asp-route-month="@Model.Month" asp-route-year="@Model.Year"
                   class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
