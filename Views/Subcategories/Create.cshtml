@model BudgetTracker.Models.Subcategory
@{
    ViewData["Title"] = "Add Subcategory";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h2>Add Subcategory</h2>
        <p class="text-muted">Subcategories are specific line items within a category, e.g. "Rent" under "Monthly Expenses".</p>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="CategoryId" class="form-label">Category</label>
                <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.Categories">
                    <option value="">-- Select a Category --</option>
                </select>
                <span asp-validation-for="CategoryId" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="e.g. Rent" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <hr />
            <p class="text-muted small">Target (optional) — set a dollar amount you want to have available on a monthly or yearly basis.</p>

            <div class="mb-3">
                <label asp-for="TargetAmount" class="form-label">Target Amount</label>
                <div class="input-group">
                    <span class="input-group-text">$</span>
                    <input asp-for="TargetAmount" class="form-control" type="number" min="0.01" step="0.01" placeholder="0.00" />
                </div>
                <span asp-validation-for="TargetAmount" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TargetPeriod" class="form-label">Period</label>
                <select asp-for="TargetPeriod" id="targetPeriodSelect" class="form-select">
                    <option value="">-- None --</option>
                    <option value="1">Monthly</option>
                    <option value="2">Yearly</option>
                </select>
                <span asp-validation-for="TargetPeriod" class="text-danger"></span>
            </div>

            <div class="mb-3" id="targetDayField" style="display:none">
                <label asp-for="TargetDay" class="form-label" id="targetDayLabel">Day needed</label>
                <input asp-for="TargetDay" class="form-control" type="number" min="1" max="366" step="1" />
                <span asp-validation-for="TargetDay" class="text-danger"></span>
                <div class="form-text" id="targetDayHelp"></div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-controller="Categories" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
    <script>
        const periodSelect = document.getElementById('targetPeriodSelect');
        const targetDayField = document.getElementById('targetDayField');
        const targetDayLabel = document.getElementById('targetDayLabel');
        const targetDayHelp = document.getElementById('targetDayHelp');
        function updateDayField() {
            if (periodSelect.value === '1') {
                targetDayField.style.display = '';
                targetDayLabel.textContent = 'Day of month needed (1–31)';
                targetDayHelp.textContent = 'The day of the month by which this amount should be available.';
            } else if (periodSelect.value === '2') {
                targetDayField.style.display = '';
                targetDayLabel.textContent = 'Day of year needed (1–366)';
                targetDayHelp.textContent = 'The day of the year by which this amount should be available (e.g. 180 = June 29).';
            } else {
                targetDayField.style.display = 'none';
            }
        }
        periodSelect.addEventListener('change', updateDayField);
        updateDayField();
    </script>
}
