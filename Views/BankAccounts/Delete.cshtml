@model BudgetTracker.Models.BankAccount
@{
    ViewData["Title"] = "Delete Account";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <h2>Delete Account</h2>
        <div class="alert alert-danger">
            Are you sure you want to delete <strong>@Model.Name</strong>?
            This will also delete all transactions associated with this account.
        </div>

        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Name</dd>
            <dt class="col-sm-4">Type</dt>
            <dd class="col-sm-8">@Model.AccountType</dd>
            <dt class="col-sm-4">Starting Balance</dt>
            <dd class="col-sm-8">@Model.StartingBalance.ToString("C")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
