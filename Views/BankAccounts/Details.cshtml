@model BudgetTracker.Models.BankAccount
@{
    ViewData["Title"] = Model.Name;

    var currentBalance = Model.StartingBalance
        + Model.Transactions.Sum(t => t.Inflow ?? 0)
        - Model.Transactions.Sum(t => t.Outflow ?? 0);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h2>@Model.Name</h2>
        <span class="badge bg-secondary">@Model.AccountType</span>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary">&larr; All Accounts</a>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="text-muted small">Starting Balance</div>
                <div class="fs-5">@Model.StartingBalance.ToString("C")</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center">
            <div class="card-body">
                <div class="text-muted small">Current Balance</div>
                <div class="fs-5 @(currentBalance < 0 ? "text-danger" : "text-success")">
                    @currentBalance.ToString("C")
                </div>
            </div>
        </div>
    </div>
</div>

<h5>Transactions</h5>
@if (!Model.Transactions.Any())
{
    <p class="text-muted">No transactions on this account yet.</p>
}
else
{
    <table class="table table-sm table-hover">
        <thead class="table-light">
            <tr>
                <th>Date</th>
                <th>Payee</th>
                <th>Category</th>
                <th class="text-end">Outflow</th>
                <th class="text-end">Inflow</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var t in Model.Transactions.OrderByDescending(t => t.Date))
            {
                <tr>
                    <td>@t.Date.ToString("MM/dd/yyyy")</td>
                    <td>@t.Payee</td>
                    <td>
                        @if (t.Subcategory != null)
                        {
                            @t.Subcategory.Category?.Name <text> &rsaquo; </text> @t.Subcategory.Name
                        }
                    </td>
                    <td class="text-end text-danger">
                        @(t.Outflow.HasValue ? t.Outflow.Value.ToString("C") : "")
                    </td>
                    <td class="text-end text-success">
                        @(t.Inflow.HasValue ? t.Inflow.Value.ToString("C") : "")
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<div class="mt-3">
    <a asp-controller="Transactions" asp-action="Create" asp-route-bankAccountId="@Model.Id" class="btn btn-primary">+ Add Transaction</a>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary ms-2">Edit Account</a>
</div>
